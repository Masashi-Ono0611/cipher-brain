{
  "name": "cipher-brain",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Encrypt a gbrain snapshot so only the key holder can read it (age X25519). Produces one backend-agnostic ciphertext for censorship-resistant storage.",
  "bin": {
    "cipher-brain": "bin/cipher-brain.mjs",
    "cipher-brain-mcp": "bin/cipher-brain-mcp.mjs"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "verify": "npm run build && npm run selftest && npm run selftest:profiles && npm run selftest:interop && npm run selftest:storage && npm run selftest:recovery && npm run selftest:arweave && npm run selftest:arweave-nodeps && bash scripts/cli-smoke.sh && node scripts/mcp-smoke.mjs",
    "selftest": "bash scripts/selftest.sh",
    "selftest:profiles": "bash scripts/selftest-profiles.sh",
    "selftest:interop": "bash scripts/selftest-interop.sh",
    "selftest:storage": "bash scripts/selftest-storage.sh",
    "selftest:recovery": "bash scripts/selftest-recovery.sh",
    "selftest:arweave": "node scripts/arweave-roundtrip.mjs",
    "selftest:arweave-nodeps": "node scripts/selftest-arweave-nodeps.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "peerDependencies": {
    "@ardrive/turbo-sdk": "^1.42.0",
    "arweave": "^1.15.0"
  },
  "peerDependenciesMeta": {
    "@ardrive/turbo-sdk": {
      "optional": true
    },
    "arweave": {
      "optional": true
    }
  },
  "devDependencies": {
    "arlocal": "^1.1.66",
    "arweave": "^1.15.7"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "age-encryption": "^0.3.0"
  }
}
