{
  "name": "cipher-brain",
  "version": "0.0.1",
  "type": "module",
  "description": "Encrypt a gbrain snapshot so only the key holder can read it (age X25519). Produces one backend-agnostic ciphertext for censorship-resistant storage.",
  "keywords": [
    "age",
    "encryption",
    "backup",
    "arweave",
    "mcp",
    "second-brain",
    "permanent-storage",
    "snapshot",
    "x25519",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Masashi-Ono0611/cipher-brain.git"
  },
  "homepage": "https://github.com/Masashi-Ono0611/cipher-brain#readme",
  "bugs": {
    "url": "https://github.com/Masashi-Ono0611/cipher-brain/issues"
  },
  "author": "Masashi Ono (https://github.com/Masashi-Ono0611)",
  "files": [
    "dist"
  ],
  "bin": {
    "cipher-brain": "dist/cli.mjs",
    "cipher-brain-mcp": "dist/mcp.mjs"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "prepack": "bun run scripts/build.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify": "npm run build && npm run typecheck && npm run selftest && npm run selftest:profiles && npm run selftest:interop && npm run selftest:storage && npm run selftest:recovery && npm run selftest:schedule && npm run selftest:arweave && npm run selftest:arweave-nodeps && bash scripts/cli-smoke.sh && node scripts/mcp-smoke.mjs",
    "selftest": "bash scripts/selftest.sh",
    "selftest:profiles": "bash scripts/selftest-profiles.sh",
    "selftest:interop": "bash scripts/selftest-interop.sh",
    "selftest:storage": "bash scripts/selftest-storage.sh",
    "selftest:recovery": "bash scripts/selftest-recovery.sh",
    "selftest:schedule": "bash scripts/selftest-schedule.sh",
    "selftest:arweave": "node scripts/arweave-roundtrip.mjs",
    "selftest:arweave-nodeps": "node scripts/selftest-arweave-nodeps.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "peerDependencies": {
    "@ardrive/turbo-sdk": "^1.42.0",
    "arweave": "^1.15.0"
  },
  "peerDependenciesMeta": {
    "@ardrive/turbo-sdk": {
      "optional": true
    },
    "arweave": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "arlocal": "^1.1.66",
    "arweave": "^1.15.7",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "age-encryption": "^0.3.0"
  }
}
